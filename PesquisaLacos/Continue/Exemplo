// Percorre um array de frutas, pulando a fruta "pera" e contando as demais exibidas

const array = ['maçã', 'banana', 'pera', 'uva', 'ameixa'];
let contador = 0;

for (let i of array) {
  if (i === 'pera') {
    continue;
  }
  console.log(i);
  contador += 1;
}

console.log('frutas: ' + contador);

/* Saída:
maçã
banana
uva
ameixa
frutas: 4
*/
